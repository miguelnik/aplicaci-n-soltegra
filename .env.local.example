# Copia este archivo a `.env.local` y rellena los valores reales.
# NUNCA commitees `.env.local` — sólo este `.example`.

# === Supabase ===
# Crea el proyecto en https://supabase.com (región Frankfurt o Irlanda).
# Encuentras estos valores en Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role: poder absoluto sobre la DB. SOLO en servidor (server actions, API routes).
# NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# === Resend (emails) ===
# Crea cuenta en https://resend.com y verifica el dominio de Soltegra.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=no-reply@soltegra.es

# === Notificaciones admin ===
# CSV de emails que reciben "nueva solicitud" cuando un cliente envía una.
ADMIN_NOTIFICATION_EMAILS=admin1@soltegra.es,admin2@soltegra.es

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
